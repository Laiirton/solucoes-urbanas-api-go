# Required environment variables for the API

# Supabase PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgres://postgres.xxxx:PASSWORD@aws-0-xx-xxx.pooler.supabase.com:5432/postgres?sslmode=require

# Secret key for signing JWT tokens (use a strong random string, at least 32 chars)
JWT_SECRET=change_me_to_a_strong_random_secret

# Port the server listens on (default: 8080)
PORT=8080
